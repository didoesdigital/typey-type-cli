{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es2016",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "allowJs": true,
    "outDir": "./build",
    "rootDir": "src",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // Linting
    "strict": true,
    // Turn this off while @typescript-eslint/no-unused-vars handles it:
    "noUnusedLocals": false,
    // Turn this off while @typescript-eslint/no-unused-vars handles it:
    "noUnusedParameters": false,

    // Types
    "types": ["node", "jest"]
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
